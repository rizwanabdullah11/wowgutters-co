# Copy this file to `.env.local` for local dev and `.env.production` for builds.
# NEVER commit real keys/tokens to git.

# Quote form (static export: browser POSTs to Web3Forms)
# Get a key from https://web3forms.com and set your notification email there.
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=

# Analytics (optional)
# GA4 measurement ID like "G-XXXXXXXXXX"
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
# Google Tag Manager container ID like "GTM-XXXXXXX" (optional)
NEXT_PUBLIC_GTM_ID=

# Optional business details used in schema markup (see `app/layout.tsx`)
NEXT_PUBLIC_BUSINESS_ADDRESS_LINE1=
NEXT_PUBLIC_BUSINESS_ADDRESS_LINE2=
NEXT_PUBLIC_BUSINESS_CITY=
NEXT_PUBLIC_BUSINESS_REGION=
NEXT_PUBLIC_BUSINESS_POSTCODE=
NEXT_PUBLIC_GBP_CID_URL=
NEXT_PUBLIC_TRUSTPILOT_URL=
